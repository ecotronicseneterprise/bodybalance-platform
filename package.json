{
  "name": "bodybalance-platform",
  "version": "0.1.0",
  "private": true,
  "description": "BodyBalance — AI-powered operating system for physiotherapy clinics. Implementation of BLUEPRINT.md v1.0.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace @bodybalance/web",
    "dev:admin": "npm run dev --workspace @bodybalance/admin",
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "eslint apps packages --ext .ts,.tsx"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "eslint": "^9.17.0",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.19.0"
  },
  "engines": {
    "node": ">=20"
  },
  "overrides": {
    "postcss": "^8.5.10"
  }
}
